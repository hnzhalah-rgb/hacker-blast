        </div>

        <!-- Sequence 4: Success Message -->
        <div id="step-3" class="hidden text-left">
            <div class="success-box">
                <h2 class="text-2xl font-bold mb-2 text-center">✅ BLAST BERHASIL!</h2>
                <div class="h-px bg-green-500 w-full mb-4"></div>
                <p class="text-lg mb-1">Status: <span class="text-white">Selesai</span></p>
                <p class="text-lg mb-4">Saldo Anda: <span class="text-white font-bold text-xl">Rp 2.400,00</span></p>
                
                <div class="bg-black p-3 border-l-4 border-yellow-500 italic text-sm text-yellow-200">
                    "Kesuksesan bukan tentang seberapa cepat kamu sampai, tapi tentang seberapa kuat kamu bertahan. Saldo Rp 2.400 hari ini, siapa tahu jadi Rp 2,4 Miliar esok hari. Teruslah berkarya, kawan!"
                </div>
                
                <p class="mt-4 text-center text-xs opacity-50 font-bold tracking-widest text-white">#PANTANG_MENYERAH #TECH_ENTHUSIAST</p>
            </div>
            <center><button onclick="location.reload()" class="btn-refresh text-xs">RESTART SYSTEM</button></center>
        </div>
    </div>

    <script>
        // Matrix Canvas Background
        const canvas = document.getElementById('matrix-canvas');
        const ctx = canvas.getContext('2d');
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
        const letters = "1010101010101010";
        const fontSize = 16;
        const columns = canvas.width / fontSize;
        const drops = Array(Math.floor(columns)).fill(1);

        function drawMatrix() {
            ctx.fillStyle = "rgba(0, 0, 0, 0.05)";
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            ctx.fillStyle = "#0f0";
            ctx.font = fontSize + "px monospace";
            for (let i = 0; i < drops.length; i++) {
                const text = letters.charAt(Math.floor(Math.random() * letters.length));
                ctx.fillText(text, i * fontSize, drops[i] * fontSize);
                if (drops[i] * fontSize > canvas.height && Math.random() > 0.975) drops[i] = 0;
                drops[i]++;
            }
        }
        setInterval(drawMatrix, 35);

        // Logic Sequence
        const bootEl = document.getElementById('boot-sequence');
        const logs = [
            "> System initializing...",
            "> Loading module: WA_BLASTER_FAST_MODE",
            "> Establishing connection...",
            "> Synchronizing database...",
            "> Ready to execute."
        ];

        let logIdx = 0;
        function runBoot() {
            if (logIdx < logs.length) {
                bootEl.innerHTML += logs[logIdx] + "<br>";
                logIdx++;
                setTimeout(runBoot, 300);
            } else {
                setTimeout(() => {
                    bootEl.classList.add('hidden');
                    document.getElementById('step-1').classList.remove('hidden');
                    startCountdown();
                }, 500);
            }
        }

        function startCountdown() {
            let count = 3;
            const counterEl = document.getElementById('counter');
            const itv = setInterval(() => {
                count--;
                if(count > 0) {
                    counterEl.innerText = count;
                } else {
                    clearInterval(itv);
                    showWarning();
                }
            }, 1000);
        }

        function showWarning() {
            document.getElementById('step-1').classList.add('hidden');
            document.getElementById('step-2').classList.remove('hidden');
            let time = 5; // DURASI DIUBAH KE 5 DETIK
            const timerEl = document.getElementById('timer');
            const progEl = document.getElementById('progress');
            
            const itv = setInterval(() => {
                time--;
                timerEl.innerText = time;
                progEl.style.width = ((5 - time) / 5 * 100) + "%";
                if(time <= 0) {
                    clearInterval(itv);
                    showFinal();
                }
            }, 1000);
        }

        function showFinal() {
            document.getElementById('step-2').classList.add('hidden');
            document.getElementById('step-3').classList.remove('hidden');
        }

        window.onload = runBoot;
        window.onresize = () => { canvas.width = window.innerWidth; canvas.height = window.innerHeight; };
    </script>
</body>
</html>

