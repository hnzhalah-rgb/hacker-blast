            background: transparent;
            color: #0f0;
            cursor: pointer;
            transition: 0.3s;
        }
        
        .btn-refresh:hover {
            background: #0f0;
            color: #000;
        }
    </style>
</head>
<body>

    <canvas id="matrix-canvas"></canvas>

    <div class="terminal-container">
        <!-- Sequence 1: Booting -->
        <div id="boot-sequence" class="text-left text-xs opacity-70 mb-4 h-32 overflow-hidden"></div>
        
        <!-- Sequence 2: Countdown 1 2 3 -->
        <div id="step-1" class="hidden">
            <h1 class="text-xl mb-2">MENGINISIALISASI PROTOKOL...</h1>
            <div class="countdown-number" id="counter">3</div>
        </div>

        <!-- Sequence 3: Warning 5 Seconds -->
        <div id="step-2" class="hidden">
            <div class="warning-text text-xl mb-4">PERINGATAN KRITIS!</div>
            <p class="text-sm mb-4">
                Siapkan WA Anda untuk di-blast karna waktu Anda tersisa <span id="timer" class="font-bold text-lg">5</span> detik lagi!
            </p>
            <div class="w-full bg-gray-900 h-3 rounded-full overflow-hidden">
                <div id="progress" class="bg-red-600 h-full w-0 transition-all duration-500"></div>
            </div>
